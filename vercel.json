{
  "version": 2,
  "buildCommand": "cd frontend && npm install && ./node_modules/.bin/ng build",
  "outputDirectory": "frontend/dist/frontend/browser",
  "installCommand": "cd frontend && npm install",
  "builds": [
    {
      "src": "frontend/dist/frontend/browser/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/frontend/browser/index.html"
    }
  ]
}